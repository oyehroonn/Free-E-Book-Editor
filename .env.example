# Database (PostgreSQL via Neon/Supabase/Railway)
DATABASE_URL="postgresql://user:password@host:5432/folio?sslmode=require"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional but recommended)
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# UploadThing (for image/cover uploads) — https://uploadthing.com
UPLOADTHING_TOKEN="your-uploadthing-token"

# FastAPI backend URL
FASTAPI_BASE_URL="https://book.heyharoon.io"
NEXT_PUBLIC_FASTAPI_BASE_URL="https://book.heyharoon.io"

# Optional: Stripe (for future premium subscriptions)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
